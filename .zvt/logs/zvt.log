_TYPE_CODE': '058001001', 'CURRENCY': 'CNY', 'ACCOUNT_FIRM': '中勤万信会计师事务所(特殊普通合伙)', 'LEGAL_ADVISER': '国浩律师(武汉)事务所', 'EXPAND_NAME_ABBR': None, 'ORG_PROFILE': '国际化智能装备制造领军者，深耕包装机械四十余年，业务涵盖十多个行业。'}
